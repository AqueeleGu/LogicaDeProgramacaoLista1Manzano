algoritmo "ListaEx14ConversaoMetrosCentimetros"
// Disciplina   : [Lógica de Programaçăo com VisualG]
// Professor   : Jailson
// Descriçăo   :  Leia um valor em metros e converta para centímetros.
// Autor(a)    : Gustavo Henrique Martins Neves
// Data atual  : 05/04/2026

Var
   // Seçăo de Declaraçőes das variáveis
   metros, centimetros: real
inicio
   escreva("Digite o valor em metros: ")
   leia(metros)
   centimetros <- metros * 100
   escreval("Valor em centimetros: ", centimetros)
fimalgoritmo
