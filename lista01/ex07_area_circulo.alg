algoritmo "ListaEx07AreaCirculo"
// Disciplina   : [Lógica de Programaçăo com VisualG]
// Professor   : Jailson
// Descriçăo   : Leia o valor do raio de um círculo e calcule sua área.
// Autor(a)    : Gustavo Henrique Martins Neves
// Data atual  : 05/04/2026

Var
   // Seçăo de Declaraçőes das variáveis
   raio, area: real
   pi: real
inicio
   pi <- 3.14
   escreva("Digite o raio: ")
   leia(raio)
   area <- pi * raio * raio
   escreval("Area do circulo: ", area)
fimalgoritmo
