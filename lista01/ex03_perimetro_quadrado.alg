algoritmo "ListaEx03Perimetro"
// Disciplina   : [Lógica de Programaçăo com VisualG]
// Professor   : Jailson
// Descriçăo   : Leia o valor do lado de um quadrado e calcule o perímetro.
// Autor(a)    : Gustavo Henrique Martins Neves
// Data atual  : 28/03/2026

Var
   // Seçăo de Declaraçőes das variáveis
   lado, perimetro: real
inicio
   escreva("Digite o lado do quadrado: ")
   leia(lado)
   perimetro <- 4 * lado
   escreval("Perimetro do quadrado: ", perimetro)
fimalgoritmo
