algoritmo "ListaEx02AreaDoQuadrado"
// Disciplina   : [Lógica de Programaçăo com VisualG]
// Professor   : Jailson
// Descriçăo   : Leia o valor do lado de um quadrado e calcule sua área.
// Autor(a)    : Gustavo Henrique Martins Neves
// Data atual  : 08/04/2026

Var
   // Seçăo de Declaraçőes das variáveis
   lado, area: real
inicio
   escreva("Digite o lado do quadrado: ")
   leia(lado)
   area <- lado * lado
   escreval("Area do quadrado: ", area)
fimalgoritmo
