algoritmo "ex21_perimetro_retangulo2"
// Disciplina   : [Lógica de Programaçăo com VisualG]
// Professor   : Jailson
// Descriçăo   : Algoritmo que calcula e exibe o Perímetro de um retângulo
// Autor(a)    : Gustavo Henrique Martins Neves
// Data atual  : 09/04/2026

Var
   // Seçăo de Declaraçőes das variáveis
   largura, altura, perimetro: real
inicio
   escreva("Digite a largura: ")
   leia(largura)
   escreva("Digite a altura: ")
   leia(altura)
   perimetro <- 2 * (largura + altura)
   escreval("Perimetro: ", perimetro)
fimalgoritmo
