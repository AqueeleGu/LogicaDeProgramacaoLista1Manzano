algoritmo "ListEx05PerimetroRetangulo"
// Disciplina   : [Lógica de Programaçăo com VisualG]
// Professor   : Jailson
// Descriçăo   : Leia a base e a altura de um retângulo e calcule seu perímetro.
// Autor(a)    : Gustavo Henrique Martins Neves
// Data atual  : 02/04/2026

Var
   // Seçăo de Declaraçőes das variáveis
   base, altura, perimetro: real
inicio
   escreva("Digite a base: ")
   leia(base)
   escreva("Digite a altura: ")
   leia(altura)
   perimetro <- 2 * (base + altura)
   escreval("Perimetro do retangulo: ", perimetro)
fimalgoritmo
