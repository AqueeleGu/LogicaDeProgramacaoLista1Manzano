algoritmo "ListaEx06AreaTriangulo"
// Disciplina   : [Lógica de Programaçăo com VisualG]
// Professor   : Jailson
// Descriçăo   : Leia a base e a altura de um triângulo e calcule sua área.
// Autor(a)    : Gustavo Henrique Martins Neves
// Data atual  : 05/04/2026

Var
   // Seçăo de Declaraçőes das variáveis
   base, altura, area: real
inicio
   escreva("Digite a base: ")
   leia(base)
   escreva("Digite a altura: ")
   leia(altura)
   area <- (base * altura) / 2
   escreval("Area do triangulo: ", area)
fimalgoritmo
