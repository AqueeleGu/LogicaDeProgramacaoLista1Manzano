algoritmo "L01_extra_a_produto_soma"
var
   A, B, C, D, P1, P2, S: inteiro
inicio
   escreva("A: ") leia(A)
   escreva("B: ") leia(B)
   escreva("C: ") leia(C)
   escreva("D: ") leia(D)
   P1 <- A * C
   P2 <- A * C
   S <- B + D
   escreval("Produto A*C: ", P1)
   escreval("Produto A*C: ", P2)
   escreval("Soma B+D: ", S)
fimalgoritmo
