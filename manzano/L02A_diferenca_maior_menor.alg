algoritmo "L02ADiferenca"
//  
//  
// Disciplina   : [Lógica de Programaçăo com VisualG]
// Professor   : Jailson
// Descriçăo   :  Ler dois valores numéricos inteiros e apresentar o resultado
// da diferença do maior pelo menor valor.
// Autor(a)    : Gustavo Henrique Martins Neves
// Data atual  : 22/04/2026

Var
   // Seçăo de Declaraçőes das variáveis
   A, B, diferenca: inteiro
inicio
   escreva("A: ")
   leia(A)
   escreva("B: ")
   leia(B)
   se A > B entao
      diferenca <- A - B
   senao
      diferenca <- B - A
   fimse
   escreval("Diferenca do maior pelo menor: ", diferenca)
fimalgoritmo
